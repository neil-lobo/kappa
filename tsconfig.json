{
  "$schema": "https://raw.githubusercontent.com/TypeScriptToLua/TypeScriptToLua/master/tsconfig-schema.json",
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["ESNext"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "types": ["lua-types/5.4"],
    "strict": true,
    "rootDir": ".",
    "outDir": "dist",
    "declaration": true,
    "declarationDir": "dist/@types"
  },
  "include": ["src/**/*", "spec/**/*", "types/**/*"],
  "tstl": {
    "luaTarget": "5.4",
    "buildMode": "library",
    "luaLibImport": "require-minimal",
    "noResolvePaths": ["chatterino.json"]
  }
}
